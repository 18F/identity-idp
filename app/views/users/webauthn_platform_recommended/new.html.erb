<% self.title = t('webauthn_platform_recommended.heading') %>

<%= render ADS::FormPageComponent.new(
      title: t('webauthn_platform_recommended.heading'),
      subtitle: t('webauthn_platform_recommended.description_security'),
    ) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(
          type: :neutral,
          message: t('webauthn_platform_recommended.upsell'),
          dismissible: false,
        ) %>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <%= render ButtonComponent.new(
            url: webauthn_platform_recommended_url,
            method: :post,
            params: { add_method: true },
          ).with_content(t('webauthn_platform_recommended.cta')) %>

      <%= render ButtonComponent.new(
            url: webauthn_platform_recommended_url,
            method: :post,
            variant: :tertiary,
          ).with_content(t('webauthn_platform_recommended.skip')) %>
    <% end %>
  <% end %>
<% end %>
