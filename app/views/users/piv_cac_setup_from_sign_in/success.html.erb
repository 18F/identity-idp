<% self.title = t('headings.piv_cac_login.success') %>

<%= render ADS::FormPageComponent.new(title: t('headings.piv_cac_login.success')) do |page| %>
  <% page.with_body do %>
    <%= image_tag asset_url('alerts/success.svg'), size: 90, alt: '' %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: login_add_piv_cac_success_path,
          method: :post,
        ).with_content(t('forms.buttons.continue')) %>
    <%= render ButtonComponent.new(
          url: logout_path,
          method: :delete,
          variant: :quaternary,
        ).with_content(cancel_link_text) %>
  <% end %>
<% end %>
