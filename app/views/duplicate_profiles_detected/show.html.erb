<% title = t(
     'duplicate_profiles_detected.you_may_have_duplicate_accounts',
     default: t('duplicate_profiles_detected.heading'),
   ) %>
<% self.title = title %>

<%= render ADS::FormPageComponent.new(
      title:,
      subtitle: t(
        'duplicate_profiles_detected.intro_html',
        link_html: new_tab_link_to(
          t('duplicate_profiles_detected.intro.link'),
          MarketingSite.help_center_article_url(
            category: 'manage-your-account',
            article: 'resolve-duplicate-accounts',
          ),
        ),
        app_name: APP_NAME,
        sp_name: decorated_sp_session.sp_name,
      ),
      class_name: 'ads-duplicate-profiles',
    ) do |page| %>
  <% page.with_body do %>
    <section class="ads-copy" aria-labelledby="duplicate-profiles-resolution-heading">
      <h2 id="duplicate-profiles-resolution-heading">
        <%= t('duplicate_profiles_detected.how_to_resolve') %>
      </h2>

      <ol class="ads-process-list">
        <li class="ads-process-list__item">
          <span class="ads-process-list__marker" aria-hidden="true"></span>
          <div class="ads-process-list__body">
            <h3 class="ads-process-list__heading">
              <%= t('duplicate_profiles_detected.select_an_account.heading') %>
            </h3>
            <p>
              <%= t('duplicate_profiles_detected.select_an_account.details_short') %>
            </p>
          </div>
        </li>

        <li class="ads-process-list__item">
          <span class="ads-process-list__marker" aria-hidden="true"></span>
          <div class="ads-process-list__body">
            <h3 class="ads-process-list__heading">
              <%= t('duplicate_profiles_detected.delete_duplicates.heading') %>
            </h3>
            <p>
              <%= t(
                    'duplicate_profiles_detected.delete_duplicates.details_html',
                    link_html: new_tab_link_to(
                      t('duplicate_profiles_detected.delete_duplicates.link'),
                      MarketingSite.help_center_article_url(
                        category: 'manage-your-account',
                        article: 'delete-your-account',
                      ),
                    ),
                  ) %>
            </p>
          </div>
        </li>

        <li class="ads-process-list__item">
          <span class="ads-process-list__marker" aria-hidden="true"></span>
          <div class="ads-process-list__body">
            <h3 class="ads-process-list__heading">
              <%= t('duplicate_profiles_detected.sign_back_in.heading', app_name: APP_NAME) %>
            </h3>
            <p>
              <%= t('duplicate_profiles_detected.sign_back_in.details', app_name: APP_NAME) %>
            </p>
          </div>
        </li>
      </ol>
    </section>

    <section class="ads-duplicate-profiles__accounts" aria-labelledby="duplicate-profiles-accounts-heading">
      <h2 id="duplicate-profiles-accounts-heading" class="ads-duplicate-profiles__heading">
        <%= t('duplicate_profiles_detected.accounts_list.heading') %>
      </h2>

      <%= render partial: 'duplicate_profiles_detected/account_information',
                 collection: @dupe_profiles_detected_presenter.associated_profiles,
                 as: :dupe_profile,
                 locals: { sp_name: decorated_sp_session.sp_name } %>
    </section>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: MarketingSite.help_center_article_url(
            category: 'manage-your-account',
            article: 'resolve-duplicate-accounts',
          ),
          target: '_blank',
          rel: 'noopener noreferrer',
        ).with_content(t('duplicate_profiles_detected.get_help')) %>

    <%= render ButtonComponent.new(
          url: logout_path,
          method: :delete,
          variant: :quaternary,
        ).with_content(t('duplicate_profiles_detected.sign_out')) %>
  <% end %>
<% end %>
