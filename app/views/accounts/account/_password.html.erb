<section class="ads-account__section" aria-labelledby="account-password-heading">
  <h2 id="account-password-heading" class="ads-account__heading">
    <%= t('account.dashboard.account.password.title') %>
  </h2>

  <div class="ads-account__panel">
    <div class="ads-account__row">
      <p class="ads-account__row-text ads-account__row-text--strong">
        <%= t('account.dashboard.account.password.masked') %>
      </p>

      <div class="ads-account__row-actions">
        <%= render ButtonComponent.new(
              url: manage_password_path,
              variant: :quaternary,
              size: :md,
              'aria-label': "#{t('account.dashboard.account.change')}: #{t('account.dashboard.account.password.title')}",
            ).with_content(t('account.dashboard.account.change')) %>
      </div>
    </div>
  </div>
</section>
