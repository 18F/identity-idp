<% self.title = t('titles.piv_cac_login.add') %>

<%= render ADS::FormPageComponent.new(
      title: t('titles.piv_cac_login.add'),
      subtitle: t('headings.piv_cac_login.add'),
    ) do |page| %>
  <% page.with_body do %>
    <%= render ADS::StackComponent.new(kind: :form, gap: 16, align: :stretch) do %>
      <%= render AlertComponent.new(
            type: :neutral,
            message: t('instructions.mfa.piv_cac.add_from_sign_in_html'),
            dismissible: false,
          ) %>

      <%= form_with(
            url: submit_new_piv_cac_url,
            method: :post,
            local: true,
            class: 'ads-form',
          ) do |f| %>
        <%= render ADS::StackComponent.new(kind: :form, gap: 16, align: :stretch) do %>
          <%= render InputComponent.new(
                form: f,
                attribute: :name,
                label: t('forms.piv_cac_setup.nickname'),
                required: true,
                maxlength: 20,
                autocomplete: 'off',
                error_messages: {
                  valueMissing: t('components.input.errors.nickname'),
                },
              ) %>
          <%= render ButtonComponent.new(
                type: :submit,
              ).with_content(t('forms.piv_cac_setup.submit')) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: login_add_piv_cac_prompt_path,
          method: :post,
          variant: :secondary,
        ).with_content(t('forms.piv_cac_setup.no_thanks')) %>

    <%= render ADS::LinkComponent.new(url: new_user_session_url) do %>
      <%= cancel_link_text %>
    <% end %>
  <% end %>
<% end %>
