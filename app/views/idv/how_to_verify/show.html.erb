<%= render 'idv/shared/step_indicator',
           current_step: :getting_started,
           steps: Idv::StepIndicatorConcern::STEP_INDICATOR_STEPS %>

<% self.title = @presenter.header_text %>

<%= render ADS::FormPageComponent.new(title: @presenter.header_text) do |page| %>
  <% page.with_body do %>
    <%= render ADS::StackComponent.new(gap: 32, align: :stretch) do %>
      <%= render ADS::StackComponent.new(gap: 24) do %>
        <% if defined?(error) %>
          <%= render AlertComponent.new(type: :error, dismissible: false) do %>
            <%= error %>
          <% end %>
        <% end %>

        <%= render CardComponent.new(padding: :compact) do %>
          <div class="ads-card__stack">
            <p class="ads-card__title"><%= @presenter.verify_online_text %></p>
            <p class="ads-card__description"><%= @presenter.verify_online_instruction %></p>
            <p class="ads-card__description"><%= @presenter.verify_online_description %></p>
            <p class="ads-card__description">
              <%= render ADS::LinkComponent.new(
                    url: help_center_redirect_path(
                      category: 'verify-your-identity',
                      article: 'overview',
                      flow: :idv,
                      step: :how_to_verify,
                      location: 'troubleshooting_options',
                    ),
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  ) do %>
                <%= t('doc_auth.info.verify_online_link_text') %>
                <span class="ads-sr-only"><%= t('links.new_tab') %></span>
              <% end %>
            </p>
          </div>
        <% end %>

        <%= render CardComponent.new(padding: :compact) do %>
          <div class="ads-card__stack">
            <p class="ads-card__title"><%= @presenter.verify_at_post_office_text %></p>
            <p class="ads-card__description">
              <%= @presenter.post_office_instruction %>
              <%= @presenter.post_office_description %>
            </p>
            <p class="ads-card__description">
              <%= render ADS::LinkComponent.new(
                    url: help_center_redirect_path(
                      category: 'verify-your-identity',
                      article: 'verify-your-identity-in-person',
                      flow: :idv,
                      step: :how_to_verify,
                      location: 'troubleshooting_options',
                    ),
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  ) do %>
                <%= t('doc_auth.info.verify_at_post_office_link_text') %>
                <span class="ads-sr-only"><%= t('links.new_tab') %></span>
              <% end %>
            </p>
          </div>
        <% end %>
      <% end %>

      <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
        <%= simple_form_for(
              @idv_how_to_verify_form,
              html: {
                id: nil,
                aria: { label: @presenter.online_submit },
                class: 'ads-form ads-form--align-stretch',
              },
              method: :put,
              url: idv_how_to_verify_url,
            ) do |f| %>
          <%= f.hidden_field(
                :selection,
                value: Idv::HowToVerifyForm::REMOTE,
              ) %>
          <%= render ButtonComponent.new(
                type: :submit,
              ).with_content(@presenter.online_submit) %>
        <% end %>

        <%= simple_form_for(
              @idv_how_to_verify_form,
              html: {
                id: nil,
                aria: { label: @presenter.post_office_submit },
                class: 'ads-form ads-form--align-stretch',
              },
              method: :put,
              url: idv_how_to_verify_url,
            ) do |f| %>
          <%= f.hidden_field(
                :selection,
                value: Idv::HowToVerifyForm::IPP,
              ) %>
          <%= render ButtonComponent.new(
                type: :submit,
                variant: :secondary,
              ).with_content(@presenter.post_office_submit) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
