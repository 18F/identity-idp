<% self.title = t('forms.backup_code.confirm_delete') %>

<%= render ADS::FormPageComponent.new(title: t('forms.backup_code.confirm_delete')) do |page| %>
  <% page.with_body do %>
    <p class="ads-copy ads-copy--centered"><%= t('forms.backup_code.caution_delete') %></p>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <%= render ButtonComponent.new(
            url: backup_code_delete_path,
            method: :delete,
            variant: :destructive,
          ).with_content(t('account.index.backup_code_confirm_delete')) %>

      <%= render ButtonComponent.new(
            url: account_path,
            variant: :quaternary,
          ).with_content(t('links.cancel')) %>
    <% end %>
  <% end %>
<% end %>
