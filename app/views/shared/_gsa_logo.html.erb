<% width = local_assigns[:width] %>
<% height = local_assigns[:height] %>
<% img_class = ['gsa-logo', local_assigns[:class]].compact.join(' ') %>
<img
  src="data:image/svg+xml;base64,"
  alt="General Services Administration"
  class="<%= img_class %>"
  <% if width.present? %>width="<%= width %>"<% end %>
  <% if height.present? %>height="<%= height %>"<% end %>
/>
