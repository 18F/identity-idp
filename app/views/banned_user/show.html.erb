<% self.title = t('banned_user.title') %>

<%= render ADS::FormPageComponent.new(
      title: t('banned_user.title'),
    ) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(type: :error, dismissible: false) do %>
      <%= t('banned_user.details') %>
    <% end %>
  <% end %>
<% end %>
