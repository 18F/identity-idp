<% self.title = t('forms.backup_code_regenerate.confirm') %>

<%= render ADS::FormPageComponent.new(title: t('forms.backup_code_regenerate.confirm')) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(
          type: :warning,
          message: t('forms.backup_code_regenerate.caution'),
          dismissible: false,
        ) %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: backup_code_setup_path,
          method: :post,
        ).with_content(t('account.index.backup_code_confirm_regenerate')) %>

    <%= render ButtonComponent.new(
          url: account_path,
          variant: :quaternary,
        ).with_content(t('links.cancel')) %>
  <% end %>
<% end %>
