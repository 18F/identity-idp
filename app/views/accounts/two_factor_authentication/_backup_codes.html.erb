<section class="ads-auth-methods__section" aria-labelledby="backup-codes-heading">
  <h2 id="backup-codes-heading" class="ads-auth-methods__heading">
    <%= t('account.dashboard.auth_methods.backup_codes.title') %>
  </h2>

  <div class="ads-auth-methods__panel">
    <div class="ads-auth-methods__row">
      <p class="ads-auth-methods__row-text">
        <% if TwoFactorAuthentication::BackupCodePolicy.new(current_user).configured? %>
          <%= t('account.index.backup_codes_exist') %>
          <%= render TimeComponent.new(time: @presenter.backup_codes_generated_at) %>
        <% else %>
          <%= t('account.index.backup_codes_no_exist') %>
        <% end %>
      </p>

      <% if TwoFactorAuthentication::BackupCodePolicy.new(current_user).configured? &&
            MfaPolicy.new(current_user).multiple_factors_enabled? %>
        <div class="ads-auth-methods__row-actions">
          <%= render ButtonComponent.new(
                url: backup_code_delete_path,
                variant: :quaternary,
                size: :md,
              ).with_content(t('forms.buttons.delete')) %>
        </div>
      <% end %>
    </div>

    <div class="ads-auth-methods__rule"></div>

    <% if TwoFactorAuthentication::BackupCodePolicy.new(@presenter.user).configured? %>
      <%= render ButtonComponent.new(
            url: backup_code_regenerate_path,
            variant: :secondary,
          ).with_content(t('forms.backup_code.regenerate')) %>
    <% else %>
      <%= render ButtonComponent.new(
            url: backup_code_setup_path,
            variant: :secondary,
          ).with_content(t('forms.backup_code.generate')) %>
    <% end %>
  </div>
</section>
