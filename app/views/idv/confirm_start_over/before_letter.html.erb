<% self.title = t('idv.cancel.headings.prompt.start_over') %>

<%= render 'idv/shared/step_indicator', current_step: @step_indicator_step %>

<%= render ADS::FormPageComponent.new(title: t('idv.cancel.headings.prompt.start_over')) do |page| %>
  <% page.with_body do %>
    <div class="ads-copy">
      <p><%= t('idv.cancel.description.gpo.start_over_new_address') %></p>
      <p><%= t('idv.cancel.description.gpo.continue') %></p>
    </div>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: idv_session_path(step: :request_letter),
          method: :delete,
        ).with_content(t('idv.buttons.continue_plain')) %>

    <%= render ButtonComponent.new(
          url: go_back_path || idv_request_letter_path,
          variant: :quaternary,
        ).with_content(t('forms.buttons.back')) %>
  <% end %>
<% end %>
