<%= render 'idv/shared/step_indicator', current_step: :verify_phone %>

<% self.title = t('titles.enter_2fa_code.one_time_code') %>

<% extra_actions = capture do %>
  <%= render ButtonComponent.new(
        url: idv_phone_path(step: 'phone_otp_verification'),
        variant: :quaternary,
      ).with_content(
        t('two_factor_authentication.phone_verification.troubleshooting.change_number'),
      ) %>
<% end %>

<%= render 'shared/otp_verification',
           subtitle: strip_tags(@presenter.phone_number_message),
           form_url: request.path,
           form_method: :put,
           code_value: @code,
           otp: {
             numeric: false,
             length: @otp_code_length,
             transport: @presenter.otp_delivery_preference,
           },
           resend_url: idv_resend_otp_path,
           resend_method: :post,
           extra_actions: %>
