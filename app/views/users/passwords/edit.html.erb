<% self.title = t('titles.edit_info.password') %>

<%= render ADS::FormPageComponent.new(
      title: t('headings.edit_info.password'),
      subtitle: t('instructions.password.info.lead_html', min_length: Devise.password_length.first),
    ) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(
          type: :neutral,
          title: t('instructions.password.help_text_header'),
          message: t('instructions.password.help_text'),
          dismissible: false,
        ) %>

    <% if @update_password_presenter.required_password_change? %>
      <%= render AlertComponent.new(
            type: :warning,
            message: t('users.password_compromised.warning', app_name: APP_NAME),
            dismissible: false,
          ) %>
    <% end %>

    <%= render AlertComponent.new(type: :warning, dismissible: false) do %>
      <%= t('users.edit_info.warning') %>
      <%= render ADS::LinkComponent.new(
            url: help_center_redirect_path(category: 'fraud-concerns', article: 'overview'),
            target: '_blank',
            rel: 'noopener',
          ) do %>
        <%= t('users.edit_info.link') %>
      <% end %>
    <% end %>

    <%= form_with(
          model: @update_user_password_form,
          url: manage_password_path,
          method: :patch,
          local: true,
          class: 'ads-form ads-form--gap-16',
        ) do |f| %>
      <%= render InputComponent.new(
            form: f,
            attribute: :password,
            type: :password,
            id: 'new-password',
            label: t('forms.passwords.edit.labels.password'),
            required: true,
            autocomplete: 'new-password',
            error_message: @update_user_password_form.errors.full_messages_for(:password).first,
          ) do %>
        <%= render PasswordStrengthComponent.new(
              input_id: 'new-password',
              forbidden_passwords: @update_password_presenter.forbidden_passwords,
            ) %>
      <% end %>
      <%= render InputComponent.new(
            form: f,
            attribute: :password_confirmation,
            type: :password,
            label: t('components.password_confirmation.confirm_label'),
            required: true,
            autocomplete: 'new-password',
            error_message: @update_user_password_form.errors
              .full_messages_for(:password_confirmation)
              .first,
            error_messages: {
              customError: t('components.password_confirmation.errors.mismatch'),
            },
          ) %>
      <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
        <%= render ButtonComponent.new(
              type: :submit,
            ).with_content(@update_password_presenter.submit_text) %>

        <% if !@update_password_presenter.required_password_change? %>
          <%= render ButtonComponent.new(
                url: account_settings_path,
                variant: :quaternary,
              ).with_content(t('links.cancel')) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
