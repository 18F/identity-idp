<%#
locals:
  ssn: (required)
  url: (required)
  divider: false
  click_observer_event: nil
%>
<% masked_ssn = capture do %>
  <%= render(
        'shared/masked_text',
        text: SsnFormatter.format(ssn),
        masked_text: SsnFormatter.format_masked(ssn),
        accessible_masked_text: t(
          'idv.accessible_labels.masked_ssn',
          first_number: ssn[0],
          last_number: ssn[-1],
        ),
        toggle_label: t('forms.ssn.show'),
      ) %>
<% end %>
<%= render 'idv/shared/verify_info/editable_field',
           label: t('idv.form.ssn'),
           value: masked_ssn,
           url: url,
           aria_label: t('idv.buttons.change_ssn_label'),
           divider: local_assigns[:divider],
           click_observer_event: local_assigns[:click_observer_event] %>
