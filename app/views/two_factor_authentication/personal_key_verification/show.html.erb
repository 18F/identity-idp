<% self.title = t('titles.enter_2fa_code.security_code') %>
<% key_word_length = RandomPhrase::WORD_LENGTH %>
<% key_word_count = IdentityConfig.store.recovery_code_length %>

<%= render ADS::FormPageComponent.new(
      title: t('two_factor_authentication.personal_key_header_text'),
      subtitle: t('two_factor_authentication.personal_key_prompt'),
    ) do |page| %>
  <% page.with_body do %>
    <%= form_with(
          model: @personal_key_form,
          url: login_two_factor_personal_key_path,
          method: :post,
          local: true,
          class: 'ads-form',
        ) do |f| %>
      <%= render ADS::StackComponent.new(kind: :form, gap: 16, align: :stretch) do %>
        <%= render InputOtpComponent.new(
              form: f,
              name: :personal_key,
              label: t('forms.two_factor.personal_key'),
              length: key_word_length * key_word_count,
              groups: Array.new(key_word_count, key_word_length),
              separator: '-',
              numeric: false,
              transport: nil,
              autocomplete: 'off',
              autofocus: true,
              autocapitalize: 'none',
              spellcheck: false,
            ) %>

        <%= render ButtonComponent.new(
              type: :submit,
            ).with_content(t('forms.buttons.continue')) %>
      <% end %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :links, align: :center) do %>
      <%= render ADS::LinkComponent.new(
            url: login_two_factor_options_path,
          ).with_content(t('two_factor_authentication.login_options_link_text')) %>
      <%= render ADS::LinkComponent.new(
            url: sign_out_path,
          ).with_content(cancel_link_text) %>
    <% end %>
  <% end %>
<% end %>
