<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.first_name'),
           value: pii[:first_name] %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.last_name'),
           value: pii[:last_name],
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.dob'),
           value: I18n.l(Date.parse(pii[:dob]), format: I18n.t('time.formats.event_date')),
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.issuing_state'),
           value: pii[:state_id_jurisdiction],
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.id_number'),
           value: pii[:state_id_number],
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.address1'),
           value: pii[:identity_doc_address1],
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.address2'),
           value: pii[:identity_doc_address2].presence,
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.city'),
           value: pii[:identity_doc_city],
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.state'),
           value: pii[:identity_doc_address_state],
           divider: true %>
<%= render 'idv/shared/verify_info/field',
           label: t('idv.form.zipcode'),
           value: pii[:identity_doc_zipcode],
           divider: true %>
