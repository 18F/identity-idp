<%= render 'idv/shared/step_indicator', current_step: :verify_address %>

<% if @user_did_not_receive_letter %>
  <% self.title = t('idv.gpo.did_not_receive_letter.title') %>
  <%= render 'did_not_receive_letter' %>
<% else %>
  <% self.title = t('idv.gpo.title') %>
  <%= render 'enter_code' %>
<% end %>
