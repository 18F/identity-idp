<% self.title = t('titles.piv_cac_setup.upsell') %>

<%= render ADS::FormPageComponent.new(
      title: t('titles.piv_cac_setup.upsell'),
      subtitle: t('two_factor_authentication.piv_cac_upsell.recommendation'),
    ) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(
          type: :neutral,
          message: t('two_factor_authentication.piv_cac_upsell.explain'),
          dismissible: false,
        ) %>

    <% if FeatureManagement.account_creation_device_profiling_collecting_enabled? %>
      <%= render partial: 'shared/threat_metrix_profiling',
                 locals: {
                   threatmetrix_session_id:,
                   threatmetrix_javascript_urls:,
                   threatmetrix_iframe_url:,
                 } %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: login_piv_cac_recommended_add_path,
          method: :post,
        ).with_content(t('two_factor_authentication.piv_cac_upsell.add_piv')) %>

    <%= render ButtonComponent.new(
          url: login_piv_cac_recommended_skip_path,
          method: :post,
          variant: :tertiary,
        ).with_content(@recommended_presenter.skip_text) %>
  <% end %>
<% end %>
