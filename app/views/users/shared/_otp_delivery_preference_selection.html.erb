<% form_name = form_obj.class.name.underscore.to_s
   form_name_label = form_name + '[otp_delivery_preference]'
   form_name_tag_sms = form_name + '_otp_delivery_preference_sms'
   form_name_tag_voice = form_name + '_otp_delivery_preference_voice'
   outage_status = OutageStatus.new
   sms_outage = outage_status.vendor_outage?(:sms)
   voice_outage = outage_status.vendor_outage?(:voice) %>

<fieldset
  class="js-otp-delivery-preferences ads-fieldset"
  aria-label="<%= t('two_factor_authentication.otp_delivery_preference.title') %>"
  aria-describedby="otp_delivery_preference_instruction"
>
  <p
    class="ads-fieldset__hint"
    id="otp_delivery_preference_instruction"
    aria-live="polite"
    hidden
  ></p>

  <div class="ads-radio-group">
    <div class="ads-radio">
      <%= radio_button_tag(
            form_name_label,
            :sms,
            form_obj.delivery_preference_sms?,
            disabled: sms_outage,
            data: { vendor_outage: sms_outage },
            class: 'js-otp-delivery-preference ads-radio__input ads-sr-only',
          ) %>
      <%= label_tag(
            form_name_tag_sms,
            t('two_factor_authentication.otp_delivery_preference.sms'),
            class: 'ads-radio__label',
          ) %>
    </div>

    <div class="ads-radio">
      <%= radio_button_tag(
            form_name_label,
            :voice,
            form_obj.delivery_preference_voice?,
            disabled: voice_outage,
            data: { vendor_outage: voice_outage },
            class: 'js-otp-delivery-preference ads-radio__input ads-sr-only',
          ) %>
      <%= label_tag(
            form_name_tag_voice,
            t('two_factor_authentication.otp_delivery_preference.voice'),
            class: 'ads-radio__label',
          ) %>
    </div>
  </div>
</fieldset>
<%= javascript_packs_tag_once('otp-delivery-preference') %>
