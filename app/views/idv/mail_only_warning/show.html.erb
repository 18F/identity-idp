<% self.title = t('vendor_outage.alerts.pinpoint.idv.header') %>

<%= render 'idv/shared/step_indicator', current_step: :getting_started %>

<%= render ADS::FormPageComponent.new(title: t('vendor_outage.alerts.pinpoint.idv.header')) do |page| %>
  <% page.with_body do %>
    <div class="ads-copy">
      <p>
        <%= t(
              'vendor_outage.alerts.pinpoint.idv.message_html',
              sp_name_html: current_sp&.friendly_name || APP_NAME,
            ) %>
      </p>

      <% status_page_link_html = capture do %>
        <%= render ADS::LinkComponent.new(
              url: StatusPage.base_url,
              target: '_blank',
              rel: 'noopener noreferrer',
            ) do %>
          <%= t('vendor_outage.alerts.pinpoint.idv.status_page_link') %>
          <span class="ads-sr-only"><%= t('links.new_tab') %></span>
        <% end %>
      <% end %>

      <p>
        <%= t(
              'vendor_outage.alerts.pinpoint.idv.status_page_html',
              link_html: status_page_link_html,
            ) %>
      </p>
    </div>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <%= render ButtonComponent.new(url: idv_url).with_content(
            t('vendor_outage.alerts.pinpoint.idv.verify_by_mail'),
          ) %>

      <%= render ButtonComponent.new(
            url: exit_url,
            variant: :quaternary,
          ).with_content(t('links.exit_login', app_name: APP_NAME)) %>
    <% end %>
  <% end %>
<% end %>
