<% self.title = t('two_factor_authentication.auth_app.edit_heading') %>

<%= render ADS::FormPageComponent.new(title: t('two_factor_authentication.auth_app.edit_heading')) do |page| %>
  <% page.with_body do %>
    <%= form_with(
          model: @form,
          scope: :form,
          method: :put,
          url: auth_app_path(id: @form.configuration.id),
          local: true,
          class: 'ads-form',
        ) do |f| %>
      <%= render ADS::StackComponent.new(kind: :form, gap: 16, align: :stretch) do %>
        <%= render InputComponent.new(
              form: f,
              attribute: :name,
              label: t('two_factor_authentication.auth_app.nickname'),
              error_message: @form.errors.full_messages_for(:name).first,
            ) %>

        <%= render ButtonComponent.new(
              type: :submit,
            ).with_content(t('two_factor_authentication.auth_app.change_nickname')) %>
      <% end %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: confirm_delete_auth_app_path(id: @form.configuration.id),
          variant: :destructive,
        ).with_content(t('two_factor_authentication.auth_app.delete')) %>

    <%= render ButtonComponent.new(
          url: account_security_path,
          variant: :secondary,
        ).with_content(t('links.cancel')) %>
  <% end %>
<% end %>
