<% self.title = t('idv.proofing_agent_expired.heading') %>

<%= render ADS::FormPageComponent.new(
      title: t('idv.proofing_agent_expired.heading'),
      subtitle: t('idv.proofing_agent_expired.body'),
    ) do |page| %>
  <% page.with_body do %>
    <%= simple_form_for(
          '',
          url: idv_proofing_agent_expired_path,
          method: :post,
          html: { class: 'ads-form ads-form--align-stretch' },
        ) do %>
      <%= render ButtonComponent.new(size: :lg, type: :submit).with_content(
            t('idv.proofing_agent_expired.continue'),
          ) %>
    <% end %>
  <% end %>
<% end %>
