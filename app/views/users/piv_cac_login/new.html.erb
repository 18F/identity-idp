<% self.title = @presenter.title %>

<%= render ADS::FormPageComponent.new(
      title: @presenter.heading,
      subtitle: @presenter.info,
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <%= render ButtonComponent.new(
            url: @presenter.piv_cac_service_link,
          ).with_content(@presenter.piv_cac_capture_text) %>

      <%= render ButtonComponent.new(
            url: new_user_session_url,
            variant: :quaternary,
          ).with_content(cancel_link_text) %>
    <% end %>
  <% end %>
<% end %>
