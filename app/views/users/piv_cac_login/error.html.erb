<% self.title = @presenter.title %>

<%= render ADS::FormPageComponent.new(
      title: @presenter.heading,
      subtitle: strip_tags(@presenter.description),
    ) do |page| %>
  <% page.with_actions do %>
    <% if @presenter.error == 'user.not_found' %>
      <%= render ButtonComponent.new(
            url: new_user_session_url,
          ).with_content(t('instructions.mfa.piv_cac.back_to_sign_in')) %>

      <%= render ButtonComponent.new(
            url: sign_up_email_url,
            variant: :secondary,
          ).with_content(t('links.create_account')) %>
    <% else %>
      <%= render ButtonComponent.new(
            url: login_piv_cac_url,
          ).with_content(t('instructions.mfa.piv_cac.try_again')) %>

      <%= render ButtonComponent.new(
            url: new_user_session_url,
            variant: :secondary,
          ).with_content(t('instructions.mfa.piv_cac.back_to_sign_in')) %>
    <% end %>
  <% end %>
<% end %>
