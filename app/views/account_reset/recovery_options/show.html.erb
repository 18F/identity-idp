<% self.title = t('account_reset.recovery_options.header') %>

<%= render ADS::FormPageComponent.new(
      title: t('account_reset.recovery_options.header'),
      subtitle: t('account_reset.recovery_options.help_text', app_name: APP_NAME),
    ) do |page| %>
  <% page.with_body do %>
    <% try_method_link_html = capture do %>
      <%= render ADS::LinkComponent.new(url: login_two_factor_options_path) do %>
        <%= t('account_reset.recovery_options.try_method_description_link') %>
      <% end %>
    <% end %>

    <% webauthn_help_link_html = capture do %>
      <%= render ADS::LinkComponent.new(
            url: MarketingSite.help_center_article_url(
              category: 'trouble-signing-in',
              article: 'face-or-touch-unlock',
            ),
            target: '_blank',
            rel: 'noopener',
          ) do %>
        <%= t('account_reset.recovery_options.check_webauthn_platform_help_link') %>
      <% end %>
    <% end %>

    <div class="ads-copy">
      <ul class="ads-list">
        <li>
          <strong><%= t('account_reset.recovery_options.try_method_again') %></strong><br>
          <%= t(
                'account_reset.recovery_options.try_method_description_html',
                link_html: try_method_link_html,
              ) %>
        </li>
        <li>
          <strong><%= t('account_reset.recovery_options.use_device') %></strong><br>
          <%= t('account_reset.recovery_options.try_another_device') %>
        </li>
        <li>
          <strong><%= t('account_reset.recovery_options.check_webauthn_platform_header') %></strong><br>
          <%= t(
                'account_reset.recovery_options.check_webauthn_platform_info_html',
                app_name: APP_NAME,
                link_html: webauthn_help_link_html,
              ) %>
        </li>
      </ul>
    </div>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: account_reset_request_path,
          variant: :destructive,
        ).with_content(t('account_reset.recover_options.yes_delete')) %>

    <%= render ButtonComponent.new(
          url: account_reset_recovery_options_cancel_path,
          method: :post,
          variant: :quaternary,
        ).with_content(t('account_reset.recovery_option.cancel_deletion')) %>
  <% end %>
<% end %>
