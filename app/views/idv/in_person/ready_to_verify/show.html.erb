<% self.title = t('in_person_proofing.headings.finish_in_person') %>
<% content_for :ads_shell, 'flow' %>
<% content_for :ads_surface, 'plain' %>
<% content_for :ads_align, 'mobile-start' %>
<%= render 'idv/shared/step_indicator', current_step: :go_to_the_post_office %>

<%= render ADS::FormPageComponent.new(
      title: t('in_person_proofing.headings.finish_in_person'),
      subtitle: t(
        'in_person_proofing.body.barcode.instructions_html',
        deadline: @presenter.formatted_due_date,
      ).html_safe,
      class_name: 'ads-ready-to-verify',
    ) do |page| %>
  <% if @presenter.selected_location_details.present? %>
    <% page.with_body do %>
      <section
        class="ads-ready-to-verify__location-panel"
        aria-label="<%= t('in_person_proofing.body.barcode.location_details') %>"
      >
        <address class="ads-ready-to-verify__location">
          <div class="ads-ready-to-verify__location-details">
            <p class="ads-ready-to-verify__location-name">
              <%= @presenter.selected_location_details['name'] %>
            </p>
            <p>
              <%= @presenter.selected_location_details['street_address'] %><br>
              <%= @presenter.selected_location_details['formatted_city_state_zip'] %>
            </p>
          </div>

          <div class="ads-ready-to-verify__location-hours">
            <h2><%= t('in_person_proofing.body.barcode.hours_heading') %></h2>
            <p>
              <%= t('date.range', from: t('date.day_names')[1], to: t('date.day_names')[5]) %>:
              <%= @presenter.selected_location_hours(:weekday) %><br>
              <%= t('date.day_names')[6] %>: <%= @presenter.selected_location_hours(:saturday) %><br>
              <%= t('date.day_names')[7] %>: <%= @presenter.selected_location_hours(:sunday) %>
            </p>
          </div>
        </address>
      </section>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <% if @presenter.service_provider_homepage_url.present? %>
        <%= render ClickObserverComponent.new(
              event_name: 'IdV: user clicked sp link on ready to verify page',
            ) do %>
          <%= render ButtonComponent.new(
                url: @presenter.service_provider_homepage_url,
              ) do %>
            <%= t(
                  'in_person_proofing.body.barcode.return_to_partner_link',
                  sp_name: @presenter.sp_name,
                ) %>
          <% end %>
        <% end %>
      <% end %>

      <%= render ButtonComponent.new(
            url: idv_cancel_path(step: 'barcode'),
            variant: :quaternary,
          ) do %>
        <%= t('in_person_proofing.body.barcode.cancel_link_text') %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
