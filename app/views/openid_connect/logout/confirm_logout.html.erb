<% self.title = t('openid_connect.logout.heading', app_name: APP_NAME) %>

<%= render ADS::FormPageComponent.new(
      title: if @service_provider_name.present?
               t(
                 'openid_connect.logout.heading_with_sp',
                 app_name: APP_NAME,
                 service_provider_name: @service_provider_name,
               )
             else
               t('openid_connect.logout.heading', app_name: APP_NAME)
             end,
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: openid_connect_logout_path,
          method: :delete,
          params: @params,
        ) do %>
      <%= t('openid_connect.logout.confirm', app_name: APP_NAME) %>
    <% end %>

    <%= render ButtonComponent.new(
          url: account_path,
          variant: :secondary,
        ).with_content(t('openid_connect.logout.deny')) %>
  <% end %>
<% end %>
