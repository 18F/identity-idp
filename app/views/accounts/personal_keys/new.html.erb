<% self.title = t('account.personal_key.get_new') %>

<%= render ADS::FormPageComponent.new(title: t('account.personal_key.get_new')) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(
          type: :warning,
          message: t('account.personal_key.get_new_description'),
          dismissible: false,
        ) %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: create_new_personal_key_path,
          method: :post,
        ).with_content(t('forms.buttons.continue')) %>

    <%= render ADS::LinkComponent.new(url: account_settings_path) do %>
      <%= t('links.cancel') %>
    <% end %>
  <% end %>
<% end %>
