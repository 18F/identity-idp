<% self.title = t('titles.verify_email') %>

<% email_notice = capture do %>
  <%= t('notices.signed_up_and_confirmed.first_paragraph_start') %>
  <strong><%= @email %></strong>
  <%= t('notices.signed_up_and_confirmed.first_paragraph_end') %>
<% end %>

<% different_email_link = render(
     ADS::LinkComponent.new(
       url: add_email_path(in_select_email_flow: @in_select_email_flow),
     ).with_content(t('notices.use_diff_email.link')),
   ) %>

<% back_url =
     if @in_select_email_flow && @pending_completions_consent
       sign_up_select_email_path
     elsif @in_select_email_flow
       account_connected_services_path
     else
       account_settings_path
     end %>

<%= render ADS::FormPageComponent.new(
      title: t('headings.verify_email'),
      subtitle: email_notice,
    ) do |page| %>
  <% page.with_body do %>
    <%= render CardComponent.new do %>
      <div class="ads-card__stack">
        <p class="ads-card__value">
          <%= t('notices.signed_up_and_confirmed.no_email_sent_explanation_start') %>
        </p>

        <%= render ButtonComponent.new(
              url: add_email_resend_path(in_select_email_flow: @in_select_email_flow),
              method: :post,
              variant: :secondary,
            ).with_content(t('links.resend')) %>

        <p class="ads-card__value">
          <%= t('notices.use_diff_email.text_html', link_html: different_email_link) %>
        </p>

        <p class="ads-card__value"><%= t('devise.registrations.close_window') %></p>
      </div>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <% if FeatureManagement.enable_load_testing_mode? && EmailAddress.find_with_email(@email) %>
      <%= render ADS::LinkComponent.new(
            url: sign_up_create_email_confirmation_url(
              confirmation_token: EmailAddress.find_with_email(@email).confirmation_token,
            ),
            id: 'confirm-now',
          ).with_content('CONFIRM NOW') %>
    <% end %>

    <%= render ButtonComponent.new(
          url: back_url,
          variant: :tertiary,
        ).with_content(
          @in_select_email_flow ? t('forms.buttons.back') : t('idv.messages.return_to_profile', app_name: APP_NAME),
        ) %>
  <% end %>
<% end %>
