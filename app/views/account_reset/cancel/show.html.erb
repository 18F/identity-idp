<% self.title = t('account_reset.cancel_request.title') %>

<%= render ADS::FormPageComponent.new(
      title: t('account_reset.cancel_request.title'),
      subtitle: t('account_reset.cancel_request.are_you_sure'),
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: account_reset_cancel_path,
          method: :post,
          variant: :destructive,
        ) do %>
      <%= t('account_reset.cancel_request.cancel_button') %>
    <% end %>

    <%= render ButtonComponent.new(
          url: root_url,
          variant: :quaternary,
        ).with_content(t('account_reset.cancel_request.cancel')) %>
  <% end %>
<% end %>
