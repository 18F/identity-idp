<% page_title = t('headings.continue_on_phone.title') %>
<% idv_session = controller.send(:idv_session) %>
<% session_uuid = idv_session.document_capture_session_uuid %>
<% mobile_url = idv_hybrid_mobile_entry_url('document-capture-session': session_uuid, request_id: sp_session[:request_id]) %>
<% qr_code_data_url = RQRCode::QRCode.new(mobile_url).as_png(size: 220).to_data_url %>
<% sms_modal_id = 'hybrid-handoff-sms-modal' %>
<% self.title = page_title %>
<%= render 'idv/shared/step_indicator', current_step: :verify_id %>

<% subtitle = capture do %>
  <%= t('headings.continue_on_phone.qr_description_lead') %>
  <%= tag.button(
        t('headings.continue_on_phone.text_link'),
        type: 'button',
        class: 'ads-link',
        data: { ads_modal_open: true },
        aria: { controls: sms_modal_id, haspopup: 'dialog', expanded: false },
      ) %>
  <%= t('headings.continue_on_phone.qr_description_tail') %>
<% end %>

<div class="ads-handoff">
  <%= render ADS::FormPageComponent.new(title: page_title, subtitle:) do |page| %>
    <% page.with_body do %>
      <%= render ADS::StackComponent.new(gap: 32, align: :stretch) do %>
        <%= image_tag(
              qr_code_data_url,
              alt: t('headings.continue_on_phone.qr_alt'),
              class: 'ads-handoff__qr-image',
              width: 220,
              height: 220,
            ) %>

        <% if @upload_enabled || @post_office_enabled %>
          <div class="ads-separator" role="separator">
            <span><%= t('user_authorization_confirmation.or').downcase %></span>
          </div>

          <%= render ADS::StackComponent.new(kind: :actions, gap: 12, align: :stretch) do %>
            <% if @post_office_enabled %>
              <%= simple_form_for(
                    @idv_how_to_verify_form,
                    html: {
                      class: 'ads-form ads-form--align-stretch',
                      aria: { label: t('forms.buttons.verify_in_person') },
                    },
                    method: :put,
                    url: url_for(type: :mobile, combined: true),
                  ) do |f| %>
                <%= f.hidden_field(:selection, value: Idv::HowToVerifyForm::IPP) %>
                <%= render ButtonComponent.new(
                      type: :submit,
                      variant: :secondary,
                    ).with_content(t('forms.buttons.verify_in_person')) %>
              <% end %>
            <% end %>

            <% if @upload_enabled %>
              <%= simple_form_for(
                    :doc_auth,
                    url: url_for(type: :desktop),
                    method: 'PUT',
                    html: {
                      id: 'form-to-submit-photos-through-desktop',
                      class: 'ads-form ads-form--align-stretch',
                      aria: { label: t('forms.buttons.upload_photos') },
                    },
                  ) do |f| %>
                <%= render ButtonComponent.new(
                      type: :submit,
                      variant: :quaternary,
                    ).with_content(t('forms.buttons.continue_on_desktop')) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>

<%= render ModalComponent.new(id: sms_modal_id) do |modal| %>
  <% modal.with_title { t('headings.continue_on_phone.text_link_modal.title') } %>
  <% modal.with_description do %>
    <%= t('headings.continue_on_phone.text_link_modal.description') %>
  <% end %>

  <%= simple_form_for(
        idv_phone_form,
        as: :doc_auth,
        url: url_for(type: :mobile, combined: true),
        method: 'PUT',
        html: {
          id: 'form-to-submit-photos-through-mobile',
          class: 'ads-form ads-form--gap-16 ads-form--align-stretch',
          aria: { label: t('forms.buttons.send_link') },
        },
      ) do |f| %>
    <%= render PhoneInputComponent.new(
          form: f,
          required: true,
          delivery_methods: [:sms],
        ) %>
    <%= render ButtonComponent.new(type: :submit).with_content(t('forms.buttons.send_link')) %>
  <% end %>
<% end %>
