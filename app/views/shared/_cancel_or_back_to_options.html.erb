<% back_to_options_path = local_assigns.fetch(:back_to_options_path, authentication_methods_setup_path) %>

<%= render PageFooterComponent.new do %>
  <% if MfaPolicy.new(current_user).two_factor_enabled? && !in_multi_mfa_selection_flow? %>
    <%= link_to t('links.cancel'), account_path %>
  <% else %>
    <%= link_to t('two_factor_authentication.choose_another_option'), back_to_options_path %>
  <% end %>
<% end %>
