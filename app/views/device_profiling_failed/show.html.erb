<% self.title = t('profiling_failed.title') %>

<%= render ADS::FormPageComponent.new(
      title: t('profiling_failed.title'),
    ) do |page| %>
  <% page.with_body do %>
    <%= render AlertComponent.new(type: :error, dismissible: false) do %>
      <%= t('profiling_failed.details_html') %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(url: root_url, size: :lg) do %>
      <%= t('links.exit_login', app_name: APP_NAME) %>
    <% end %>
  <% end %>
<% end %>
