<% self.title = t('titles.verify_email') %>

<% if @resend_confirmation %>
  <%= render ToastComponent.new(message: t('notices.resend_confirmation_email.success')) %>
<% end %>

<%= render ADS::FormPageComponent.new(
      title: t('sign_up.verify_email.heading'),
      subtitle: safe_join(
        [
          t('notices.signed_up_but_unconfirmed.first_paragraph_start'),
          tag.strong(email),
          t('notices.signed_up_but_unconfirmed.first_paragraph_end'),
        ],
        ' ',
      ),
    ) do |page| %>
  <% page.with_actions do %>
    <%= form_with(
          model: @resend_email_confirmation_form,
          url: sign_up_register_path,
          local: true,
          class: 'ads-form',
        ) do |f| %>
      <%= f.hidden_field :email %>
      <%= f.hidden_field :resend %>
      <%= f.hidden_field :terms_accepted %>
      <%= render ButtonComponent.new(
            size: :lg,
            type: :submit,
          ).with_content(t('notices.signed_up_but_unconfirmed.resend_confirmation_email')) %>
    <% end %>

    <%= render ButtonComponent.new(
          size: :lg,
          url: sign_up_email_path,
          variant: :quaternary,
        ).with_content(t('sign_up.verify_email.use_different_email')) %>

    <% if FeatureManagement.enable_load_testing_mode? && EmailAddress.find_with_email(email) %>
      <%= render ADS::LinkComponent.new(
            url: sign_up_create_email_confirmation_url(
              confirmation_token: EmailAddress.find_with_email(email).confirmation_token,
            ),
            id: 'confirm-now',
          ).with_content('CONFIRM NOW') %>
    <% end %>
  <% end %>
<% end %>
