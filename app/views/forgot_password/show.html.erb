<% self.title = t('titles.verify_email') %>

<% email_notice = capture do %>
  <%= t('notices.forgot_password.first_paragraph_start') %>
  <strong><%= @email %></strong>
  <%= t('notices.forgot_password.first_paragraph_end') %>
<% end %>

<%= render ADS::FormPageComponent.new(
      title: t('headings.verify_email'),
      subtitle: email_notice,
    ) do |page| %>
  <% page.with_body do %>
    <% if @resend.present? %>
      <%= render 'forgot_password/resend_alert' %>
    <% end %>

    <%= form_with(
          model: @password_reset_email_form,
          url: user_password_path,
          local: true,
          class: 'ads-form',
        ) do |f| %>
      <%= f.hidden_field :email %>
      <%= f.hidden_field :resend %>
      <%= render ButtonComponent.new(
            type: :submit,
            variant: :secondary,
          ).with_content(t('links.resend')) %>
    <% end %>
  <% end %>
<% end %>
