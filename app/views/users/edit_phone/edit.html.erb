<% self.title = t('titles.edit_info.phone') %>

<%= render ADS::FormPageComponent.new(title: t('headings.edit_info.phone')) do |page| %>
  <% page.with_body do %>
    <%= form_with(
          model: @edit_phone_form,
          method: :put,
          url: manage_phone_path(id: @phone_configuration.id),
          class: 'ads-form',
        ) do |_f| %>
      <%= render ADS::StackComponent.new(kind: :form, gap: 16, align: :stretch) do %>
        <div class="ads-copy">
          <p>
            <%= t('two_factor_authentication.phone_label') %>:
            <strong><%= @edit_phone_form.masked_phone %></strong>
          </p>
        </div>

        <%= render 'delivery_preference_selection' %>
        <%= render 'make_default_number' %>

        <%= render ButtonComponent.new(
              type: :submit,
            ).with_content(t('forms.buttons.submit.confirm_change')) %>
      <% end %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <% if MfaPolicy.new(current_user).multiple_factors_enabled? %>
      <%= render ButtonComponent.new(
            url: confirm_delete_phone_path(id: @phone_configuration.id),
            variant: :destructive,
          ).with_content(t('forms.phone.buttons.delete')) %>
    <% end %>

    <%= render ButtonComponent.new(
          url: account_security_path,
          variant: :secondary,
        ).with_content(t('links.cancel')) %>
  <% end %>
<% end %>
