<% self.title = t('titles.visitors.index') %>

<%= render ADS::FormPageComponent.new(title: password_header) do |page| %>
  <% page.with_body do %>
    <%= form_with(
          model: current_user,
          scope: :user,
          url: capture_password_url,
          method: :post,
          local: true,
          class: 'ads-form',
        ) do |f| %>
      <%= render InputComponent.new(
            form: f,
            attribute: :password,
            type: :password,
            label: t('account.index.password'),
            required: true,
            autocomplete: 'current-password',
            error_messages: {
              valueMissing: t('components.input.errors.password_current'),
            },
          ) %>
      <%= render ButtonComponent.new(
            type: :submit,
          ).with_content(t('forms.buttons.continue')) %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::LinkComponent.new(url: new_user_password_url) do %>
      <%= t('links.passwords.forgot') %>
    <% end %>
  <% end %>
<% end %>
