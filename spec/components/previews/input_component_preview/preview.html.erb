<%
  examples = [
    ['Empty', :empty, {}],
    ['Filled', :filled, { value: 'patriot@example.com' }],
    ['Password', :password, { type: :password, value: 'correct-horse-battery-staple' }],
    ['Phone', :phone, { type: :tel, value: '2025550199' }],
    [
      'Phone with country code',
      :phone_country,
      { type: :tel, country_selector: true, selected_country: 'US', value: '' },
    ],
    [
      'Error',
      :invalid,
      { value: 'not an email', error_message: 'Enter a valid email address.' },
    ],
    ['Readonly', :readonly, { value: 'readonly@login.gov', readonly: true }],
  ]
%>
<%= form_with(url: '#', scope: :preview, local: true) do |form| %>
  <div style="display: flex; flex-direction: column; gap: 24px; max-width: 27rem;">
    <% examples.each do |title, attribute, options| %>
      <div>
        <p style="margin: 0 0 12px; font: 600 12px/1 system-ui;"><%= title %></p>
        <%= render InputComponent.new(
              form:,
              attribute:,
              label: (attribute == :phone_country ? t('two_factor_authentication.phone_label') : title),
              **options,
            ) %>
      </div>
    <% end %>
  </div>
<% end %>
