<% self.title = t('idv.gpo.title') %>

<% timeout = distance_of_time_in_words(
     Time.zone.now,
     [@expires_at, Time.zone.now].compact.max,
     except: :seconds,
   ) %>

<%= render ADS::FormPageComponent.new(title: t('idv.failure.gpo.rate_limited.heading')) do |page| %>
  <% page.with_body do %>
    <div class="ads-copy ads-copy--centered">
      <p><%= t('errors.enter_code.rate_limited_html', timeout:) %></p>
    </div>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: return_to_sp_failure_to_proof_path(
            step: 'verify_address',
            location: request.params[:action],
          ),
          variant: :secondary,
        ) do %>
      <% if decorated_sp_session.sp_name.present? %>
        <%= t(
              'idv.failure.exit.with_sp',
              app_name: APP_NAME,
              sp_name: decorated_sp_session.sp_name,
            ) %>
      <% else %>
        <%= t('idv.failure.exit.without_sp', app_name: APP_NAME) %>
      <% end %>
    <% end %>

    <%= render ButtonComponent.new(
          url: contact_redirect_url,
          variant: :quaternary,
          target: '_blank',
          rel: 'noopener noreferrer',
        ) do %>
      <%= t('idv.troubleshooting.options.contact_support', app_name: APP_NAME) %>
      <span class="ads-sr-only"><%= t('links.new_tab') %></span>
    <% end %>
  <% end %>
<% end %>
