<% self.title = t('titles.present_piv_cac') %>

<%= render ADS::FormPageComponent.new(
      title: @presenter.header,
      subtitle: t('instructions.mfa.piv_cac.confirm_piv_cac'),
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: @presenter.piv_cac_service_link,
        ).with_content(@presenter.piv_cac_capture_text) %>

    <%= render ButtonComponent.new(
          url: login_two_factor_options_path,
          variant: :quaternary,
        ).with_content(t('two_factor_authentication.login_options_link_text')) %>
  <% end %>
<% end %>
