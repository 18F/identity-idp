<% self.title = @presenter.heading %>

<%= render ADS::FormPageComponent.new(title: @presenter.heading) do |page| %>
  <% page.with_body do %>
    <div class="ads-copy ads-copy--centered">
      <p><%= @presenter.description %></p>
      <p><%= t('webauthn_setup_mismatch.description_undo') %></p>
    </div>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <%= render ButtonComponent.new(
            url: webauthn_setup_mismatch_url,
            method: :patch,
          ).with_content(t('forms.buttons.continue')) %>

      <%= render ButtonComponent.new(
            url: webauthn_setup_mismatch_url,
            method: :delete,
            variant: :secondary,
          ).with_content(t('webauthn_setup_mismatch.undo')) %>
    <% end %>
  <% end %>
<% end %>
