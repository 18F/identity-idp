<% self.title = t('titles.forget_all_browsers') %>

<%= render ADS::FormPageComponent.new(
      title: t('titles.forget_all_browsers'),
      subtitle: t('account.forget_all_browsers.longer_description'),
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: forget_all_browsers_path,
          method: :delete,
          variant: :destructive,
        ).with_content(t('forms.buttons.confirm')) %>

    <%= render ADS::LinkComponent.new(url: account_path) do %>
      <%= t('links.cancel') %>
    <% end %>
  <% end %>
<% end %>
