<% self.title = t('forms.backup_code_reminder.heading') %>

<%= render ADS::FormPageComponent.new(
      title: t('forms.backup_code_reminder.heading'),
      subtitle: t('forms.backup_code_reminder.body_info'),
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: backup_code_reminder_path,
          method: :post,
          params: { has_codes: true },
        ).with_content(t('forms.backup_code_reminder.have_codes')) %>

    <%= render ButtonComponent.new(
          url: backup_code_reminder_path,
          method: :post,
          variant: :tertiary,
        ).with_content(t('forms.backup_code_reminder.need_new_codes')) %>
  <% end %>
<% end %>
