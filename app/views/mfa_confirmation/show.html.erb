<% self.title = @content.heading %>
<%# Page copy already confirms the method was added; suppress redundant success toast. %>
<% flash.delete(:success) %>

<%= render ADS::FormPageComponent.new(
      title: @content.heading,
      subtitle: @content.info,
    ) do |page| %>
  <% page.with_actions do %>
    <%= render ButtonComponent.new(
          url: authentication_methods_setup_path,
        ).with_content(@content.button) %>

    <% if @content.show_skip_additional_mfa_link? %>
      <%= render ButtonComponent.new(
            url: auth_method_confirmation_skip_path,
            method: :post,
            variant: :quaternary,
          ).with_content(t('mfa.skip')) %>
    <% end %>
  <% end %>
<% end %>
