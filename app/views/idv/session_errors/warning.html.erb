<% self.title = t('titles.failure.information_not_verified') %>

<%= render 'idv/shared/step_indicator', current_step: :verify_info, steps: @step_indicator_steps %>

<%= render ADS::FormPageComponent.new(title: t('idv.warning.sessions.heading')) do |page| %>
  <% page.with_body do %>
    <div class="ads-copy">
      <p><%= t('idv.failure.sessions.warning') %></p>
      <p><%= t('idv.failure.attempts_html', count: @remaining_submit_attempts) %></p>
    </div>
  <% end %>

  <% page.with_actions do %>
    <%= render ADS::StackComponent.new(kind: :actions, gap: 8, align: :stretch) do %>
      <%= render ButtonComponent.new(url: @try_again_path).with_content(
            t('idv.forgot_password.try_again'),
          ) %>

      <%= render ButtonComponent.new(
            url: idv_cancel_path(step: :invalid_session),
            variant: :quaternary,
          ).with_content(t('links.cancel')) %>
    <% end %>
  <% end %>
<% end %>
