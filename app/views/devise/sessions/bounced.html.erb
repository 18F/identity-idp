<% self.title = t('headings.sp_handoff_bounced', sp_name: @sp_name) %>

<%= render ADS::FormPageComponent.new(title: t('headings.sp_handoff_bounced', sp_name: @sp_name)) do |page| %>
  <% page.with_body do %>
    <% sp_link = @sp_name %>
    <% if @sp_link.present? %>
      <% sp_link = capture do %>
        <%= render ADS::LinkComponent.new(url: @sp_link) do %>
          <%= @sp_name %>
        <% end %>
      <% end %>
    <% end %>

    <%= render AlertComponent.new(type: :warning, dismissible: false) do %>
      <%= t(
            'instructions.sp_handoff_bounced',
            app_name: APP_NAME,
            sp_name: @sp_name,
            sp_link: sp_link,
          ) %>
    <% end %>
  <% end %>

  <% page.with_actions do %>
    <%= render ButtonComponent.new(url: root_url) do %>
      <%= t('instructions.mfa.piv_cac.back_to_sign_in') %>
    <% end %>
  <% end %>
<% end %>
