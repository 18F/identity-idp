<% self.title = t('titles.two_factor_setup') %>
<% option_order = %i[webauthn_platform auth_app phone webauthn backup_code piv_cac] %>
<% options = @presenter.options.sort_by { |o|
     [o.disabled? ? 0 : 1, option_order.index(o.type) || 99]
   } %>

<%= simple_form_for @two_factor_options_form,
                    method: :patch,
                    url: authentication_methods_setup_path do %>
  <%= render ADS::FormPageComponent.new(
        title: @presenter.heading,
        subtitle: @presenter.intro,
      ) do |page| %>
    <% page.with_body do %>
      <%= render ADS::StackComponent.new(kind: :form, gap: 24, align: :stretch) do %>
        <%= render(
              VendorOutageAlertComponent.new(
                vendors: [:sms, :voice],
                context: :voice,
                only_if_all: true,
              ),
            ) %>

        <%= render ADS::StackComponent.new(gap: 12, align: :stretch) do %>
          <% options.each do |option| %>
            <%= render(option) do %>
              <%= render partial: 'partials/multi_factor_authentication/mfa_selection',
                         locals: { option: option } %>
            <% end %>
          <% end %>
        <% end %>

        <%= hidden_field_tag :platform_authenticator_available,
                             id: 'platform_authenticator_available' %>
        <% javascript_packs_tag_once('platform-authenticator-available') %>
        <% if FeatureManagement.account_creation_device_profiling_collecting_enabled? %>
          <%= render partial: 'shared/threat_metrix_profiling',
                     locals: {
                       threatmetrix_session_id:,
                       threatmetrix_javascript_urls:,
                       threatmetrix_iframe_url:,
                     } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
