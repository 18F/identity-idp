<%= render ModalComponent.new(id: 'reactivate-account-modal', class: 'reactivate-account-modal') do |modal| %>
  <% modal.with_title do %>
    <%= t('instructions.account.reactivate.modal.heading') %>
  <% end %>

  <% modal.with_description do %>
    <%= t('instructions.account.reactivate.modal.copy') %>
  <% end %>

  <% modal.with_footer do %>
    <%= form_tag reactivate_account_path, method: :put, class: 'ads-form' do %>
      <%= render ButtonComponent.new(type: :submit, name: :personal_key) do %>
        <%= t('forms.buttons.continue') %>
      <% end %>
    <% end %>

    <%= render ButtonComponent.new(
          type: :button,
          variant: :secondary,
          data: { ads_modal_close: true },
        ) do %>
      <%= t('links.cancel') %>
    <% end %>
  <% end %>
<% end %>
