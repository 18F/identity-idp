<% self.title = t('titles.sign_up.create_password') %>

<%= render ADS::FormPageComponent.new(
      title: t('titles.sign_up.create_password'),
      subtitle: t(
        'instructions.password.info.lead_html',
        min_length: Devise.password_length.first,
      ),
    ) do |page| %>
  <% page.with_body do %>
    <%= form_with(
          model: @password_form,
          url: sign_up_create_password_path,
          local: true,
          class: 'ads-form',
        ) do |f| %>
      <%= render ADS::StackComponent.new(kind: :form, gap: 32, align: :stretch) do %>
        <%= render ADS::StackComponent.new(kind: :form, gap: 12, align: :stretch) do %>
          <%= text_field_tag(
                'username',
                @email_address.email,
                hidden: true,
                autocomplete: 'username',
              ) %>
          <%= render InputComponent.new(
                form: f,
                attribute: :password,
                label: t('forms.password'),
                type: :password,
                id: 'password',
                required: true,
                autocomplete: 'new-password',
                error_message: @password_form.errors.full_messages_for(:password).first,
              ) %>
          <%= render InputComponent.new(
                form: f,
                attribute: :password_confirmation,
                label: t('components.password_confirmation.confirm_label'),
                type: :password,
                required: true,
                autocomplete: 'new-password',
                error_message: @password_form.errors
                  .full_messages_for(:password_confirmation)
                  .first,
                error_messages: {
                  customError: t('components.password_confirmation.errors.mismatch'),
                },
              ) %>
          <%= render PasswordStrengthComponent.new(
                input_id: 'password',
                forbidden_passwords: @forbidden_passwords,
              ) %>
          <%= hidden_field_tag :confirmation_token, @confirmation_token, id: 'confirmation_token' %>
          <%= hidden_field_tag(
                :platform_authenticator_available,
                nil,
                id: 'platform_authenticator_available',
              ) %>
        <% end %>

        <%= render ButtonComponent.new(
              size: :lg,
              type: :submit,
            ).with_content(t('forms.buttons.continue')) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= javascript_packs_tag_once('platform-authenticator-available', preload_links_header: false) %>
