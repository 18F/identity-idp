<% generated_on = local_assigns[:personal_key_generated_at].presence || Time.zone.today %>
<% formatted_date = I18n.l(generated_on, format: I18n.t('time.formats.event_date')) %>
<% code_html = safe_join(
     code.split('-').map { |word| tag.strong(word, class: 'ads-personal-key-display__word') },
     ' - ',
   ) %>

<div class="ads-personal-key-display">
  <p class="ads-personal-key-display__meta">
    <%= t('forms.personal_key.generated_on', date: formatted_date) %>
  </p>

  <div class="ads-personal-key-display__code">
    <% if local_assigns[:code_example] %>
      <span class="ads-sr-only"><%= t('users.personal_key.accessible_labels.code_example') %></span>
      <code aria-hidden="true"><%= code_html %></code>
    <% else %>
      <code><%= code_html %></code>
    <% end %>
  </div>

  <% if show_save_buttons %>
    <hr class="ads-card__divider">

    <%= render ADS::StackComponent.new(
          kind: :actions,
          gap: 8,
          class: 'ads-action-row',
        ) do %>
      <%= render ClipboardButtonComponent.new(
            clipboard_text: code,
            variant: :quaternary,
            size: :sm,
          ) %>
      <%= render ClickObserverComponent.new(event_name: 'IdV: download personal key') do %>
        <%= render DownloadButtonComponent.new(
              file_data: code,
              file_name: 'personal_key.txt',
              variant: :quaternary,
              size: :sm,
            ) %>
      <% end %>
      <%= render PrintButtonComponent.new(
            variant: :quaternary,
            size: :sm,
          ) %>
    <% end %>
  <% end %>
</div>
